---
interface Props {
  label: string;
  value: string | number;
  sub?: string;
  color?: string;
}
const { label, value, sub, color = '#3b82f6' } = Astro.props;
---
<div class="rounded-xl p-5 border border-slate-700/50" style="background:#1e293b;">
  <div class="text-sm text-slate-400 mb-1">{label}</div>
  <div class="text-3xl font-bold" style={`color:${color}`}>{value}</div>
  {sub && <div class="text-xs text-slate-500 mt-1">{sub}</div>}
</div>
