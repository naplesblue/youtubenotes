---
interface Props {
  label: string;
  value: string | number;
  sub?: string;
  color?: string;
}
const { label, value, sub, color } = Astro.props;
---
<div class="card">
  <div class="text-[11px] uppercase tracking-wider mb-2" style="color:var(--color-text-muted);">{label}</div>
  <div class="font-data text-2xl font-bold" style={color ? `color:${color}` : 'color:var(--color-text)'}>{value}</div>
  {sub && <div class="text-[11px] mt-1.5" style="color:var(--color-text-muted);">{sub}</div>}
</div>
