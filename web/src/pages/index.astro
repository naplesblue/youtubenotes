---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import StatCard from '../components/StatCard.astro';
import SentimentBadge from '../components/SentimentBadge.astro';
import type { DashboardData } from '../lib/types';

import dataRaw from '../../public/data/dashboard.json';
const data = dataRaw as unknown as DashboardData;
const { stats, activity, tickers } = data;

// Top 10 tickers by opinion count
const topTickers = [...tickers]
  .sort((a, b) => b.active_opinions - a.active_opinions)
  .slice(0, 10);
---
<DashboardLayout title="概览 — YTNotes Dashboard" current="/">
  <h1 class="text-2xl font-bold mb-6">概览</h1>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <StatCard label="视频" value={stats.total_videos} color="#3b82f6" />
    <StatCard label="频道" value={stats.total_channels} color="#8b5cf6" />
    <StatCard label="观点" value={stats.total_opinions} color="#f59e0b" />
    <StatCard label="Ticker" value={stats.total_tickers} color="#22c55e" />
    <StatCard label="验证进度" value={`${stats.verified_count}/${stats.verifiable_opinions}`}
              sub={`${stats.pending_count} 待验证`} color="#ef4444" />
    <StatCard label="数据跨度" value={stats.date_range.start ? `${stats.date_range.start.slice(5)}` : '—'}
              sub={stats.date_range.end ? `至 ${stats.date_range.end.slice(5)}` : ''} color="#06b6d4" />
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Activity Timeline -->
    <div class="lg:col-span-2 rounded-xl border border-slate-700/50 p-5" style="background:#1e293b;">
      <h2 class="text-lg font-semibold mb-4">最近活动</h2>
      <div class="space-y-3 max-h-[600px] overflow-y-auto">
        {activity.map(event => (
          <div class="flex items-start gap-3 text-sm">
            <div class="text-xs text-slate-500 w-16 shrink-0 pt-0.5">{event.date.slice(5)}</div>
            <div class={`w-2 h-2 rounded-full mt-1.5 shrink-0 ${event.type === 'video' ? 'bg-blue-400' : 'bg-amber-400'}`} />
            <div class="flex-1 min-w-0">
              <span class="text-slate-400">{event.channel}</span>
              {event.type === 'video' ? (
                <span class="text-slate-300 ml-1 truncate block">{event.title}</span>
              ) : (
                <span class="ml-1">
                  <span class={`inline-block px-1.5 py-0.5 rounded text-xs font-medium ${
                    event.sentiment?.includes('bullish') ? 'bg-green-500/20 text-green-400' :
                    event.sentiment?.includes('bearish') ? 'bg-red-500/20 text-red-400' :
                    'bg-slate-500/20 text-slate-400'
                  }`}>{event.ticker}</span>
                </span>
              )}
              {event.tickers && event.tickers.length > 0 && (
                <div class="flex gap-1 mt-1 flex-wrap">
                  {event.tickers.slice(0, 5).map((t: string) => (
                    <span class="text-xs px-1.5 py-0.5 rounded bg-slate-700 text-slate-300">{t}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Top Tickers -->
    <div class="rounded-xl border border-slate-700/50 p-5" style="background:#1e293b;">
      <h2 class="text-lg font-semibold mb-4">热门 Ticker Top 10</h2>
      <div class="space-y-2">
        {topTickers.map((t, i) => {
          const maxCount = topTickers[0]?.active_opinions || 1;
          const pct = (t.active_opinions / maxCount) * 100;
          const ws = t.consensus.weighted_sentiment;
          const barColor = ws > 0.2 ? '#22c55e' : ws < -0.2 ? '#ef4444' : '#64748b';
          return (
            <a href={`/tickers/${t.ticker}/`} class="flex items-center gap-3 group">
              <span class="text-xs text-slate-500 w-5">{i + 1}</span>
              <span class="text-sm font-medium w-14 group-hover:text-blue-400 transition-colors">{t.ticker}</span>
              <div class="flex-1 h-5 rounded bg-slate-800 overflow-hidden">
                <div class="h-full rounded transition-all" style={`width:${pct}%;background:${barColor}`} />
              </div>
              <span class="text-xs text-slate-400 w-6 text-right">{t.active_opinions}</span>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</DashboardLayout>
