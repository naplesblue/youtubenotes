---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import StatCard from '../components/StatCard.astro';
import ActivityFeed from '../components/ActivityFeed.tsx';
import type { DashboardData } from '../lib/types';

import dataRaw from '../../public/data/dashboard.json';
const data = dataRaw as unknown as DashboardData;
const { stats, activity, tickers, videos, opinions } = data;

const topTickers = [...tickers]
  .sort((a, b) => b.active_opinions - a.active_opinions)
  .slice(0, 10);
---
<DashboardLayout title="概览 — YTNotes" current="/">
  <div class="mb-8">
    <h1 class="text-xl font-semibold mb-1">概览</h1>
    <p class="text-[13px]" style="color:var(--color-text-muted);">
      {stats.total_channels} 个频道 · {stats.total_opinions} 条观点 · {stats.total_tickers} 个标的
    </p>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-10">
    <StatCard label="视频" value={stats.total_videos} />
    <StatCard label="频道" value={stats.total_channels} />
    <StatCard label="观点" value={stats.total_opinions} color="var(--color-amber)" />
    <StatCard label="标的" value={stats.total_tickers} />
    <StatCard label="已验证" value={`${stats.verified_count}/${stats.verifiable_opinions}`}
              sub={`${stats.pending_count} 待验证`} />
    <StatCard label="数据跨度" value={stats.date_range.start ? stats.date_range.start.slice(5) : '—'}
              sub={stats.date_range.end ? `至 ${stats.date_range.end.slice(5)}` : ''} />
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
    <!-- Activity Timeline -->
    <div class="lg:col-span-3 card-flush">
      <div class="px-5 pt-4 pb-3">
        <div class="section-title">最近动态</div>
      </div>
      <ActivityFeed client:load activity={activity} videos={videos} opinions={opinions} />
    </div>

    <!-- Top Tickers -->
    <div class="lg:col-span-2 card">
      <div class="section-title">热门标的</div>
      <div class="space-y-3">
        {topTickers.map((t, i) => {
          const maxCount = topTickers[0]?.active_opinions || 1;
          const pct = (t.active_opinions / maxCount) * 100;
          const ws = t.consensus.weighted_sentiment;
          const barColor = ws > 0.2 ? 'var(--color-green)' : ws < -0.2 ? 'var(--color-red)' : 'var(--color-text-muted)';
          return (
            <a href={`/tickers/${t.ticker}/`} class="flex items-center gap-3 group">
              <span class="font-data text-[11px] w-4 text-right" style="color:var(--color-text-muted);">{i + 1}</span>
              <span class="font-data text-[13px] w-14 group-hover:text-[var(--color-accent)] transition-colors">{t.ticker}</span>
              <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background:var(--color-border);">
                <div class="h-full rounded-full transition-all" style={`width:${pct}%;background:${barColor};opacity:0.7;`} />
              </div>
              <span class="font-data text-[11px] w-5 text-right" style="color:var(--color-text-muted);">{t.active_opinions}</span>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</DashboardLayout>
