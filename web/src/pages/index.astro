---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import StatCard from '../components/StatCard.astro';
import ActivityFeed from '../components/ActivityFeed.tsx';
import type { DashboardData } from '../lib/types';

import dataRaw from '../../public/data/dashboard.json';
const data = dataRaw as unknown as DashboardData;
const { stats, activity, tickers, videos, opinions } = data;

// Ticker tape: all tickers with price data, sorted by opinion count
const tickerTape = [...tickers]
  .filter(t => t.price_data?.length > 0)
  .sort((a, b) => b.active_opinions - a.active_opinions)
  .map(t => {
    const series = t.price_data || [];
    const last = series.length > 0 ? series[series.length - 1].close : null;
    const prev = series.length > 6 ? series[series.length - 6].close : (series[0]?.close ?? null);
    const delta7d = (last != null && prev != null && prev !== 0)
      ? ((last - prev) / prev) * 100
      : null;
    const ws = t.consensus.weighted_sentiment;
    return { ticker: t.ticker, lastClose: last, delta7d, ws, opinions: t.active_opinions };
  });

// Verification stats
const verifiable = opinions.filter(o => !['reference_only', 'stop_loss'].includes(o.prediction?.type));
const verified30 = verifiable.filter(o => {
  const r = o.verification?.snapshots?.['30d']?.result;
  return r === 'win' || r === 'loss';
}).length;
const verified90 = verifiable.filter(o => {
  const r = o.verification?.snapshots?.['90d']?.result;
  return r === 'win' || r === 'loss';
}).length;
const verified180 = verifiable.filter(o => {
  const r = o.verification?.snapshots?.['180d']?.result;
  return r === 'win' || r === 'loss';
}).length;

// Active channels
const channelCounts = opinions.reduce((acc, o) => {
  const ch = o.channel || '';
  if (!ch) return acc;
  acc[ch] = (acc[ch] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const topChannels = Object.entries(channelCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

const dateRangeLabel = stats.date_range.start && stats.date_range.end
  ? `${stats.date_range.start.slice(5)} → ${stats.date_range.end.slice(5)}`
  : '—';
---
<DashboardLayout title="概览 — 美股风向标" current="/">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-semibold mb-1">概览</h1>
    <p class="text-[13px]" style="color:var(--color-text-muted);">
      {stats.total_channels} 个频道 · {stats.total_opinions} 条观点 · {stats.total_tickers} 个标的
    </p>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-4 mb-6 items-start">
    <div><StatCard label="视频" value={stats.total_videos} /></div>
    <div><StatCard label="频道" value={stats.total_channels} /></div>
    <div><StatCard label="观点" value={stats.total_opinions} color="var(--color-amber)" /></div>
    <div><StatCard label="标的" value={stats.total_tickers} /></div>
    <div><StatCard label="数据跨度" value={dateRangeLabel} /></div>
  </div>

  <!-- Ticker Tape -->
  <div class="card-flush mb-8">
    <div class="px-5 pt-4 pb-1">
      <div class="section-title">Ticker 快览</div>
    </div>
    <div class="px-4 pb-4">
      <div class="ticker-tape">
      {tickerTape.map(t => {
        const deltaColor = t.delta7d == null ? 'var(--color-text-muted)'
          : t.delta7d >= 0 ? 'var(--color-green)' : 'var(--color-red)';
        const sentDot = t.ws > 0.2 ? 'dot-bull' : t.ws < -0.2 ? 'dot-bear' : 'dot-neutral';
        return (
          <a href={`/tickers/${t.ticker}/`} class="tape-chip">
            <span class={`tape-dot ${sentDot}`} />
            <span class="font-data tape-sym">{t.ticker}</span>
            {t.lastClose != null && (
              <span class="font-data tape-price">${t.lastClose.toFixed(1)}</span>
            )}
            <span class="font-data tape-delta" style={`color:${deltaColor};`}>
              {t.delta7d == null ? '—' : `${t.delta7d >= 0 ? '+' : ''}${t.delta7d.toFixed(1)}%`}
            </span>
          </a>
        );
      })}
      </div>
    </div>
  </div>

  <!-- Two-column layout -->
  <div class="grid grid-cols-12 gap-6 items-start">
    <!-- Left: Activity Feed -->
    <div class="col-span-12 xl:col-span-8 card-flush">
      <div class="px-5 pt-4 pb-3">
        <div class="section-title">最近动态</div>
      </div>
      <ActivityFeed client:load activity={activity} videos={videos} opinions={opinions} />
    </div>

    <!-- Right sidebar -->
    <div class="col-span-12 xl:col-span-4 flex flex-col gap-5">
      <!-- Active Channels -->
      <div class="card">
        <div class="section-title mb-3">活跃频道</div>
        <div class="space-y-2.5">
          {topChannels.map(([channel, count]) => {
            const maxCount = topChannels[0]?.[1] || 1;
            const pct = (count / maxCount) * 100;
            return (
              <div class="flex items-center gap-3">
                <span class="truncate text-[12px] w-[140px] shrink-0" style="color:var(--color-text-secondary);">{channel}</span>
                <div class="flex-1 h-1 rounded-full overflow-hidden" style="background:var(--color-border);">
                  <div class="h-full rounded-full" style={`width:${pct}%;background:var(--color-accent);opacity:0.5;`} />
                </div>
                <span class="font-data text-[11px] w-5 text-right shrink-0" style="color:var(--color-text-muted);">{count}</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Verification Progress -->
      <div class="card">
        <div class="section-title mb-3">回验进度</div>
        <div class="grid grid-cols-3 gap-3">
          <div class="verify-box">
            <div class="verify-label">30d</div>
            <div class="font-data verify-val">{verified30}<span class="verify-total">/{verifiable.length}</span></div>
          </div>
          <div class="verify-box">
            <div class="verify-label">90d</div>
            <div class="font-data verify-val">{verified90}<span class="verify-total">/{verifiable.length}</span></div>
          </div>
          <div class="verify-box">
            <div class="verify-label">180d</div>
            <div class="font-data verify-val">{verified180}<span class="verify-total">/{verifiable.length}</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  /* ── Ticker Tape ── */
  .ticker-tape {
    display: flex;
    flex-wrap: nowrap;
    gap: 4px;
    overflow-x: auto;
    padding: 4px 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .ticker-tape::-webkit-scrollbar { display: none; }

  .tape-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 8px;
    white-space: nowrap;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .tape-chip:hover {
    background: var(--color-surface-hover);
  }

  .tape-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-bull { background: var(--color-green); }
  .dot-bear { background: var(--color-red); }
  .dot-neutral { background: var(--color-text-muted); }

  .tape-sym {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text);
  }
  .tape-price {
    font-size: 11px;
    color: var(--color-text-muted);
  }
  .tape-delta {
    font-size: 11px;
    font-weight: 500;
  }

  /* ── Verify boxes ── */
  .verify-box {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-hover);
    padding: 10px 12px;
  }
  .verify-label {
    font-size: 11px;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }
  .verify-val {
    font-size: 14px;
    color: var(--color-text);
  }
  .verify-total {
    font-size: 11px;
    color: var(--color-text-muted);
  }
</style>
