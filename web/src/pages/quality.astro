---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import QualityReport from '../components/QualityReport.tsx';
import type { DashboardData } from '../lib/types';

import dataRaw from '../../public/data/dashboard.json';
const data = dataRaw as unknown as DashboardData;
---
<DashboardLayout title="数据质量 — YTNotes" current="/quality/">
  <div class="mb-8">
    <h1 style="font-size:20px;font-weight:600;margin-bottom:4px;color:var(--color-text);">数据质量</h1>
    <p style="font-size:13px;color:var(--color-text-muted);">
      对 {data.stats.total_opinions} 条观点和 {data.stats.total_tickers} 个标的的自动检查
    </p>
  </div>
  <QualityReport client:load issues={data.data_quality} />
</DashboardLayout>
