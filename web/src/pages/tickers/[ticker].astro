---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PriceChart from '../../components/PriceChart.tsx';
import OpinionTable from '../../components/OpinionTable.tsx';
import type { DashboardData, Ticker, Opinion } from '../../lib/types';

import dataRaw from '../../../public/data/dashboard.json';
const data = dataRaw as unknown as DashboardData;

export function getStaticPaths() {
  const d = dataRaw as unknown as DashboardData;
  return d.tickers.map(t => ({
    params: { ticker: t.ticker },
    props: { tickerData: t },
  }));
}

const { tickerData } = Astro.props;
const ticker = tickerData as Ticker;

// Get full opinions for this ticker
const tickerOpinions = data.opinions.filter(o => o.ticker === ticker.ticker);

const ws = ticker.consensus.weighted_sentiment;
const wsColor = ws > 0.2 ? '#22c55e' : ws < -0.2 ? '#ef4444' : '#64748b';
const wsLabel = ws > 0.2 ? '偏多' : ws < -0.2 ? '偏空' : '中性';
---
<DashboardLayout title={`${ticker.ticker} — YTNotes Dashboard`} current="/tickers/">
  <div class="mb-6">
    <a href="/tickers/" class="text-sm text-slate-500 hover:text-slate-300">← Ticker 网格</a>
  </div>

  <div class="flex items-baseline gap-4 mb-6">
    <h1 class="text-2xl font-bold">{ticker.ticker}</h1>
    <span class="text-slate-400">{ticker.company_name}</span>
    <span class="text-sm px-2 py-0.5 rounded font-medium" style={`background:${wsColor}20;color:${wsColor}`}>
      {wsLabel} ({ws >= 0 ? '+' : ''}{ws.toFixed(2)})
    </span>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
    <div class="rounded-xl p-4 border border-slate-700/50" style="background:#1e293b;">
      <div class="text-xs text-slate-400">看多</div>
      <div class="text-xl font-bold text-green-400">{ticker.consensus.bullish_count}</div>
    </div>
    <div class="rounded-xl p-4 border border-slate-700/50" style="background:#1e293b;">
      <div class="text-xs text-slate-400">看空</div>
      <div class="text-xl font-bold text-red-400">{ticker.consensus.bearish_count}</div>
    </div>
    <div class="rounded-xl p-4 border border-slate-700/50" style="background:#1e293b;">
      <div class="text-xs text-slate-400">中性</div>
      <div class="text-xl font-bold text-slate-400">{ticker.consensus.neutral_count}</div>
    </div>
    <div class="rounded-xl p-4 border border-slate-700/50" style="background:#1e293b;">
      <div class="text-xs text-slate-400">目标均价</div>
      <div class="text-xl font-bold text-blue-400">
        {ticker.consensus.avg_target_price ? `$${ticker.consensus.avg_target_price.toFixed(0)}` : '—'}
      </div>
    </div>
    <div class="rounded-xl p-4 border border-slate-700/50" style="background:#1e293b;">
      <div class="text-xs text-slate-400">支撑均价</div>
      <div class="text-xl font-bold text-amber-400">
        {ticker.consensus.avg_support_price ? `$${ticker.consensus.avg_support_price.toFixed(0)}` : '—'}
      </div>
    </div>
  </div>

  <!-- Price Chart -->
  <div class="rounded-xl border border-slate-700/50 p-5 mb-6" style="background:#1e293b;">
    <h2 class="text-lg font-semibold mb-3">价格走势 + 观点标记</h2>
    <div class="flex gap-4 text-xs text-slate-500 mb-2">
      <span><span class="inline-block w-2 h-2 rounded-full bg-green-500 mr-1"></span>看多</span>
      <span><span class="inline-block w-2 h-2 rounded-full bg-red-500 mr-1"></span>看空</span>
      <span><span class="inline-block w-2 h-2 rounded-full bg-slate-500 mr-1"></span>中性</span>
    </div>
    <PriceChart client:load ticker={ticker} />
  </div>

  <!-- Analysts -->
  {ticker.top_analysts.length > 0 && (
    <div class="rounded-xl border border-slate-700/50 p-5 mb-6" style="background:#1e293b;">
      <h2 class="text-lg font-semibold mb-3">分析师共识</h2>
      <div class="flex gap-3 flex-wrap">
        {ticker.top_analysts.map(a => {
          const cls = a.sentiment.includes('bullish') ? 'border-green-500/30 bg-green-500/5'
            : a.sentiment.includes('bearish') ? 'border-red-500/30 bg-red-500/5'
            : 'border-slate-700 bg-slate-800/50';
          return (
            <a href={`/bloggers/${encodeURIComponent(a.analyst)}/`}
               class={`rounded-lg border px-4 py-2 hover:scale-105 transition-transform ${cls}`}>
              <div class="font-medium text-sm">{a.analyst}</div>
              <div class="text-xs text-slate-400">{a.channel}</div>
            </a>
          );
        })}
      </div>
    </div>
  )}

  <!-- Opinions Table -->
  <div class="rounded-xl border border-slate-700/50 p-5" style="background:#1e293b;">
    <h2 class="text-lg font-semibold mb-3">全部观点 ({tickerOpinions.length})</h2>
    <OpinionTable client:load opinions={tickerOpinions} showChannel={true} />
  </div>
</DashboardLayout>
