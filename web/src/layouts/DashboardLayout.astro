---
import '../styles/global.css';

interface Props {
  title?: string;
  current?: string;
}
const { title = 'YoutubeNotes Dashboard', current = '' } = Astro.props;

const navItems = [
  { href: '/', label: '概览', icon: '📊' },
  { href: '/bloggers/', label: '博主', icon: '👤' },
  { href: '/tickers/', label: 'Ticker', icon: '📈' },
  { href: '/quality/', label: '数据质量', icon: '🔍' },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen" style="background:#0f172a;color:#f1f5f9;font-family:Inter,system-ui,sans-serif;">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-56 shrink-0 border-r border-slate-700/50 p-4 flex flex-col gap-1 sticky top-0 h-screen"
           style="background:#0f172a;">
      <div class="text-lg font-bold mb-6 px-3 py-2">
        <span style="color:#3b82f6;">YT</span>Notes
      </div>
      {navItems.map(item => (
        <a href={item.href}
           class:list={[
             'flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors',
             current === item.href
               ? 'bg-blue-500/15 text-blue-400 font-medium'
               : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800',
           ]}>
          <span>{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
      <div class="mt-auto text-xs text-slate-600 px-3">
        静态仪表盘 · Astro
      </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 p-6 overflow-auto">
      <slot />
    </main>
  </div>
</body>
</html>
