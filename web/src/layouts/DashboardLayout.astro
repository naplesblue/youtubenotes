---
import '../styles/global.css';

interface Props {
  title?: string;
  current?: string;
}
const { title = '美股风向标 · NasdaqBeats', current = '' } = Astro.props;

const navItems = [
  { href: '/', label: '概览' },
  { href: '/bloggers/', label: '分析师' },
  { href: '/tickers/', label: '标的' },
  { href: '/quality/', label: '数据质量' },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <!-- Prevent flash: apply theme before paint -->
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('ytn-theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.setAttribute('data-theme', saved);
      } else if (saved === 'auto' || !saved) {
        // Auto: 7am-18pm = light, else dark
        var h = new Date().getHours();
        document.documentElement.setAttribute('data-theme', (h >= 7 && h < 18) ? 'light' : 'dark');
      }
    })();
  </script>
</head>
<body>
  <div class="min-h-screen" style="background:var(--color-bg);transition:background 0.3s;">
    <header class="sticky top-0 z-40" style="background:color-mix(in srgb, var(--color-bg) 88%, transparent);border-bottom:1px solid var(--color-border);backdrop-filter:blur(8px);">
      <div class="w-full max-w-[1360px] mx-auto px-4 py-3 xl:px-8 2xl:px-10 flex items-center gap-4">
        <a href="/" class="shrink-0 leading-tight no-underline">
          <div class="text-[17px] font-semibold tracking-tight" style="color:var(--color-text);">美股风向标</div>
          <div class="font-data text-[10px] uppercase tracking-[0.12em]" style="color:var(--color-text-muted);">NasdaqBeats</div>
        </a>

        <nav class="flex-1 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none]">
          <div class="min-w-max flex items-center gap-1">
            {navItems.map(item => (
              <a href={item.href}
                 class:list={[
                   'block px-3 py-1.5 rounded-md text-[13px] transition-all',
                   current === item.href
                     ? 'font-medium'
                     : 'hover:bg-[var(--color-surface)]',
                 ]}
                 style={current === item.href
                   ? 'color:var(--color-text);background:var(--color-surface);'
                   : 'color:var(--color-text-muted);'}>
                {item.label}
              </a>
            ))}
          </div>
        </nav>

        <div class="shrink-0">
          <div class="theme-toggle" id="theme-toggle">
            <button data-mode="light" title="浅色">☀</button>
            <button data-mode="auto" title="自动（按时间）">◑</button>
            <button data-mode="dark" title="深色">☾</button>
          </div>
        </div>
      </div>
    </header>

    <main class="px-4 py-6 xl:px-8 2xl:px-10">
      <div class="w-full max-w-[1360px] mx-auto">
        <slot />
      </div>
    </main>
  </div>

  <script is:inline>
    (function() {
      var toggle = document.getElementById('theme-toggle');
      if (!toggle) return;
      var buttons = toggle.querySelectorAll('button');

      function getResolved(mode) {
        if (mode === 'light' || mode === 'dark') return mode;
        var h = new Date().getHours();
        return (h >= 7 && h < 18) ? 'light' : 'dark';
      }

      function apply(mode) {
        localStorage.setItem('ytn-theme', mode);
        document.documentElement.setAttribute('data-theme', getResolved(mode));
        buttons.forEach(function(b) {
          b.classList.toggle('active', b.getAttribute('data-mode') === mode);
        });
      }

      // Init
      var saved = localStorage.getItem('ytn-theme') || 'auto';
      apply(saved);

      buttons.forEach(function(b) {
        b.addEventListener('click', function() {
          apply(b.getAttribute('data-mode'));
        });
      });
    })();
  </script>
</body>
</html>
