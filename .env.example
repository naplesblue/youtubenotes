# =========================================================
# Core pipeline (youtube_downloader.py + audio_analyzer.py)
# =========================================================

# Enable YouTube cookies for restricted videos: 1=enable, 0=disable
YTDLP_USE_COOKIES=0

# Path to Netscape-format cookies file used by yt-dlp
YTDLP_COOKIES_PATH=./data/youtube_cookies.txt

# Cleanup downloaded media files in youtube_downloader.py (1=enable, 0=disable)
YTDLP_CLEANUP_DOWNLOAD_FILES=1

# DashScope API key for Qwen text analysis (required by audio_analyzer.py)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI-compatible endpoint for DashScope
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Text model name for analysis
LLM_MODEL_NAME=qwen-plus

# Transcript routing mode in audio_analyzer.py: auto|subtitle|asr
TRANSCRIPT_MODE=auto

# Preferred manual subtitle languages (comma-separated, automatic captions are ignored)
SUBTITLE_PREFERRED_LANGS=en,en-us,en-gb

# Subtitle probe/download timeout seconds
SUBTITLE_PROBE_TIMEOUT=120
SUBTITLE_DOWNLOAD_TIMEOUT=240

# Quality gate for subtitle-to-analysis path
SUBTITLE_MIN_CHARS=800
SUBTITLE_MIN_CUES=30
SUBTITLE_MIN_COVERAGE=0.60
SUBTITLE_MIN_ENGLISH_RATIO=0.70

# Optional: absolute/relative path to funasr_transcribe.py
# Default is ./funasr_transcribe.py (same directory as audio_analyzer.py)
FUNASR_SCRIPT_PATH=./funasr_transcribe.py

# Optional: path to FunASR remote_code model.py (file path or directory)
# If empty, resolver order: ./model.py -> ModelScope cache -> funasr built-in model.py
FUNASR_MODEL_PY_PATH=

# Optional: local FunASR model directory (skip remote model-id lookup if set)
# Example: ~/.cache/modelscope/hub/models/FunAudioLLM/Fun-ASR-Nano-2512
FUNASR_MODEL_DIR=

# Optional: inference device (cpu|auto|mps|cuda:0)
# Default cpu for stability / lower memory peak
FUNASR_DEVICE=cpu

# Optional: enable VAD model (1/0). Default 0 to reduce extra memory usage.
FUNASR_ENABLE_VAD=0

# Optional: chunk length (seconds) for long-audio segmentation.
# Current best value in this project: 60
FUNASR_CHUNK_SECONDS=60

# Optional: append custom hotwords for FunASR, separated by spaces
FUNASR_HOTWORDS=

# Optional: sentence timestamp mode for FunASR generate call
# auto: try True then fallback False
# 0/false: always use sentence_timestamp=False
FUNASR_SENTENCE_TIMESTAMP=0

# Optional: set 1/true to enable verbose traceback logs in funasr_transcribe.py
FUNASR_VERBOSE=0

# Optional: enable persistent FunASR worker in audio_analyzer.py (1/0)
# Current stable baseline in this project: 0 (disable worker)
FUNASR_USE_WORKER=0

# Optional: worker recycle policy (helps cap long-running memory footprint)
# max jobs per worker before auto-exit (0 = unlimited)
FUNASR_WORKER_MAX_JOBS=6
# idle seconds before auto-exit
FUNASR_WORKER_IDLE_TIMEOUT=180
# max lifetime seconds before auto-exit
FUNASR_WORKER_MAX_SECONDS=1800
# request timeout for each transcription task
FUNASR_WORKER_REQUEST_TIMEOUT=1800
# startup timeout for first model load
FUNASR_WORKER_STARTUP_TIMEOUT=900
# retries for worker request failure (0 = no retry)
FUNASR_WORKER_MAX_RETRIES=1
# fallback to one-shot CLI if worker fails (1/0); default 0 to avoid repeated heavy loads
FUNASR_FALLBACK_TO_CLI_ON_WORKER_ERROR=0

# Optional: audio_analyzer.py run-scope controls
# ANALYZER_ONLY_VIDEO=NkNqGo98ey0
# ANALYZER_MAX_VIDEOS=1

# =========================================================
# Obsidian sync overrides (obsidian_sync.py / lib/config/loader.py)
# =========================================================

# Optional: override paths.vault in config.yaml
# OBSIDIAN_VAULT_DIR=/absolute/path/to/your/obsidian/vault

# Optional: override paths.analysis_output in config.yaml
# ANALYSIS_OUTPUT_DIR=/absolute/path/to/data/results

# Optional: override logging.level (debug|info|warn|error)
LOG_LEVEL=info

# =========================================================
# Optional scripts (report_enhancer.py / upload_to_notion.py)
# =========================================================

# Gemini / Google AI
GOOGLE_API_KEY=your_google_api_key_here

# Optional OpenAI fallback for report_enhancer.py
OPENAI_API_KEY=your_openai_api_key_here

# report_enhancer model settings
VISION_MODEL_NAME=gemini-2.5-flash
TEXT_MODEL_NAME=gemini-2.5-flash
FALLBACK_MODEL_NAME=gpt-4o-mini

# Notion + Cloudinary (upload_to_notion.py)
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
ENABLE_IMAGE_UPLOAD=true
